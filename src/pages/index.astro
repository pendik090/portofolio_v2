---
import BaseLayout from "@/layouts/BaseLayout.astro"
import FadeUp from "@/components/FadeUp.astro"
import ProjectCard from "@/components/ProjectCard.astro"
import StatusTypewriter from "@/components/StatusTypewriter"
import { techStack, projects } from "@/data/projects"
import { site, stats } from "@/data/site"
import { socials } from "@/data/social"
import { ArrowRight, ArrowUpRight, MapPin } from "@lucide/astro"

const featured = projects.slice(0, 4)
---

<BaseLayout>
  <!-- Hero -->
  <FadeUp>
  <section>
    <div class="flex-1">
      <StatusTypewriter client:load />
    </div>
    <div class="flex flex-row items-start gap-2 sm:gap-2 sm:items-center">
      <div class="min-w-0 flex-1">
        <h1 class="mt-6 text-balance text-xl font-semibold leading-[1.1] tracking-tight sm:text-5xl">
          Hi, I&apos;m {site.name}.
          <span class="block font-serif text-xl italic text-muted-foreground sm:text-4xl">
            {site.role}.
          </span>
        </h1>

        <p class="mt-2 max-w-md text-pretty text-sm text-start sm:text-align leading-relaxed text-muted-foreground sm:max-w-md sm:text-base sm:mt-6">
          {site.intro}
        </p>
      </div>

      <div class="shrink-0">
        <img src={site.avatar} alt={site.name}
          class="w-32 h-32 mt-16 rounded-full object-cover ring-2 border-4 border-background sm:w-72 sm:h-72 sm:mt-0"
        />
      </div>
    </div>
    <div class="mt-6 flex items-center gap-2 text-sm text-muted-foreground">
          <MapPin class="size-4" />
          <span>Based in {site.location}</span>
        </div>

        <!-- {
          socials.map((social) => {
            <div class="mt-6 max-w-md">
              <a href={social.link} type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border bg-transparent text-foreground transition-colors hover:bg-accent">
                <img src={social.iconLight} class="block h-4 w-4 dark:hidden"/>
                <img src={social.iconDark} class="block h-4 w-4 dark:block"/>
              </a>
            </div>
          })
        } -->

    <div class="mt-8 flex flex-wrap items-center gap-3 sm:inline-flex">
      <a
        href="/projects"
        class="inline-flex h-10 items-center justify-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        View projects
        <ArrowRight class="size-4" />
      </a>
      <a
        href="/about"
        class="inline-flex h-10 items-center justify-center rounded-md border border-border px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent"
      >
        About me
      </a>
      <a
        href={site.cvHref}
        class="inline-flex h-10 items-center justify-center gap-1 rounded-md px-2 text-sm font-medium text-muted-foreground underline-offset-4 transition-colors hover:text-foreground hover:underline"
      >
        Download CV
        <ArrowUpRight class="size-4" />
      </a>
    </div>
  </section>
  </FadeUp>

  <!-- Stats -->
  <FadeUp delay={200}>
  <section class="mt-16 grid grid-cols-3 gap-px overflow-hidden rounded-lg border border-border bg-border">
    {
      stats.map((stat) => (
        <div class="flex flex-col gap-1 bg-secondary p-5">
          <span class="text-2xl font-semibold tracking-tight sm:text-3xl">
            {stat.value}
          </span>
          <span class="text-xs leading-snug text-muted-foreground sm:text-sm">
            {stat.label}
          </span>
        </div>
      ))
    }
  </section>
  </FadeUp>

  <!-- Tech stack -->
  <FadeUp delay={400}>
  <section class="mt-16">
    <div class="flex items-baseline justify-between">
      <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
        Tech stack
      </h2>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
      {
        techStack.map((tech) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1 text-sm text-foreground transition-colors hover:bg-accent">
            <img
              src={tech.icon.light}
              alt={tech.name}
              class="block h-4 w-4 dark:hidden"
            />

            <img
              src={tech.icon.dark}
              alt={tech.name}
              class="hidden h-4 w-4 dark:block"
            />{tech.name}
          </span>
        ))
      }
    </div>
  </section>
  </FadeUp>

  <!-- Featured projects -->
  <section class="mt-16">
    <div class="flex items-baseline justify-between">
      <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
        Selected work
      </h2>
      <a
        href="/projects"
        class="group inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        All projects
        <ArrowRight class="size-3.5 transition-transform group-hover:translate-x-0.5" />
      </a>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {featured.map((project, tech) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
