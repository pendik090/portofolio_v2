---
import BaseLayout from "@/layouts/BaseLayout.astro"
import FadeUp from "@/components/FadeUp.astro"
import { projects } from "@/data/site"
import { ArrowLeft, ChevronLeft, ChevronRight, Check } from "@lucide/astro"

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

const { project } = Astro.props

const slides = [
  ...(project.video ? [{ type: "video", src: project.video }] : []),
  ...project.images.map((src) => ({ type: "image", src })),
]
---

<BaseLayout
  title={`${project.title} — Rosfendik`}
  description={project.description}
  canonical={`/projects/${project.slug}`}
  image={project.images[0]}
  type="article"
>
  <FadeUp>
  <section>
    <a
      href="/projects"
      class="inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <ArrowLeft class="size-4" />
      All projects
    </a>

    <div
      id="slider"
      class="relative mt-6 aspect-video overflow-hidden rounded-lg border border-border bg-muted"
      data-slides={JSON.stringify(slides)}
    >
      <div class="relative h-full w-full">
        <img
          id="slider-img"
          class="absolute inset-0 h-full w-full object-contain transition-opacity duration-200"
          alt={project.title}
          style="opacity:0"
        />
        <video
          id="slider-video"
          class="absolute inset-0 h-full w-full object-contain hidden"
          muted
          playsinline
          controls
        ></video>
      </div>

      <button
        id="slider-prev"
        class="absolute left-3 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-border bg-background/80 text-foreground backdrop-blur-sm transition-colors hover:bg-accent"
        aria-label="Previous slide"
      >
        <ChevronLeft class="size-4" />
      </button>
      <button
        id="slider-next"
        class="absolute right-3 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-border bg-background/80 text-foreground backdrop-blur-sm transition-colors hover:bg-accent"
        aria-label="Next slide"
      >
        <ChevronRight class="size-4" />
      </button>

      <div
        id="slider-dots"
        class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1.5"
      ></div>
    </div>

    <div class="mt-8 space-y-8">
      <FadeUp delay={200}>
      <div>
        <div class="flex items-baseline justify-between gap-4">
          <h1 class="text-2xl font-semibold leading-tight tracking-tight text-foreground sm:text-3xl">
            {project.title}
          </h1>
          <span class="shrink-0 font-mono text-sm text-muted-foreground">
            {project.year}
          </span>
        </div>
        <p class="mt-3 max-w-xl text-pretty leading-relaxed text-muted-foreground">
          {project.description}
        </p>
      </div>
      </FadeUp>

      <FadeUp delay={400}>
      <div class="rounded-lg border border-border bg-card">
        <div class="flex flex-col gap-1.5 p-6 pb-0">
          <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
            Overview
          </h2>
        </div>
        <div class="p-6 pt-3">
          <p class="leading-relaxed text-muted-foreground">
            {project.overview}
          </p>
        </div>
      </div>
      </FadeUp>

      <FadeUp delay={600}>
      <div class="rounded-lg border border-border bg-card">
        <div class="flex flex-col gap-1.5 p-6 pb-0">
          <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
            Features
          </h2>
        </div>
        <div class="p-6 pt-3">
          <ul class="space-y-3">
            {project.features.map((feature) => (
              <li class="flex items-start gap-3">
                <Check class="mt-0.5 size-4 shrink-0 text-foreground" />
                <span class="text-sm leading-relaxed text-muted-foreground">
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      </FadeUp>

      <FadeUp delay={800}>
      <div class="rounded-lg border border-border bg-card">
        <div class="flex flex-col gap-1.5 p-6 pb-0">
          <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
            Tech Stack
          </h2>
        </div>
        <div class="p-6 pt-3">
          <div class="flex flex-wrap gap-2">
            {project.tech.map((tech) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1 text-sm text-muted-foreground">
                <img
                  src={tech.iconLight}
                  alt={tech.name}
                  class="block h-4 w-4 dark:hidden"
                />
                <img
                  src={tech.iconDark}
                  alt={tech.name}
                  class="hidden h-4 w-4 dark:block"
                />
                {tech.name}
              </span>
            ))}
          </div>
        </div>
      </div>
      </FadeUp>
    </div>
  </section>
  </FadeUp>
</BaseLayout>

<script is:inline>
  const slider = document.getElementById("slider")
  if (slider) {
    const slides = JSON.parse(slider.dataset.slides || "[]")
    let index = 0
    const img = document.getElementById("slider-img")
    const video = document.getElementById("slider-video")
    const prev = document.getElementById("slider-prev")
    const next = document.getElementById("slider-next")
    const dots = document.getElementById("slider-dots")

    function render() {
      if (!slides.length) return
      const slide = slides[index]

      if (slide.type === "video") {
        img.style.opacity = "0"
        video.classList.remove("hidden")
        video.src = slide.src
        video.play()
      } else {
        video.classList.add("hidden")
        video.pause()
        video.src = ""
        img.style.opacity = "0"
        setTimeout(() => {
          img.src = slide.src
          img.onload = () => { img.style.opacity = "1" }
          if (img.complete && img.naturalWidth > 0) {
            img.style.opacity = "1"
          }
        }, 200)
      }

      if (dots) {
        dots.innerHTML = slides
          .map(
            (_, i) =>
              `<button class="size-2 rounded-full transition-colors ${i === index ? "bg-foreground" : "bg-muted-foreground/30 hover:bg-muted-foreground/60"}" data-index="${i}" aria-label="Go to slide ${i + 1}"></button>`,
          )
          .join("")
      }
    }

    if (prev)
      prev.addEventListener("click", () => {
        index = index > 0 ? index - 1 : slides.length - 1
        render()
      })
    if (next)
      next.addEventListener("click", () => {
        index = index < slides.length - 1 ? index + 1 : 0
        render()
      })
    if (dots)
      dots.addEventListener("click", (e) => {
        const dot = e.target.closest("[data-index]")
        if (dot) {
          index = Number.parseInt(dot.dataset.index)
          render()
        }
      })

    render()
  }
</script>
