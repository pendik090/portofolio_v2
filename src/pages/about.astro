---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { site, techStack, stats } from "@/data/site"
import { ArrowUpRight } from "@lucide/astro"

const skillGroups = [
  { label: "Frontend", items: ["HTML5", "CSS", "JavaScript", "TailwindCSS", "Bootstrap", "Flutter"] },
  { label: "Backend", items: ["PHP", "Laravel", "CodeIgniter", "Python", "MySQL"] },
  { label: "Tools", items: ["Git", "GitLab", "Figma", "Dart"] },
]
---

<BaseLayout title="About — Rosfendik">
  <section class="animate-fade-up">
    <h1 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
      About
    </h1>

    <div class="mt-6 space-y-5">
      <p class="text-balance font-serif text-2xl leading-snug text-foreground sm:text-3xl">
        I&apos;m {site.name}, a {site.role.toLowerCase()} based in {site.location}.
      </p>
      {
        site.about.map((para) => (
          <p class="max-w-xl text-pretty leading-relaxed text-muted-foreground">
            {para}
          </p>
        ))
      }
    </div>
  </section>

  <!-- Skills -->
  <section class="mt-14">
    <h2 class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
      What I work with
    </h2>
    <div class="mt-6 divide-y divide-border border-y border-border">
      {
        skillGroups.map((group) => (
          <div class="flex flex-col gap-3 py-5 sm:flex-row sm:items-baseline sm:gap-8">
            <span class="w-24 shrink-0 text-sm font-medium text-foreground">
              {group.label}
            </span>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="rounded-full border border-border px-3 py-1 text-sm text-muted-foreground">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quick facts -->
  <section class="mt-14 grid grid-cols-3 gap-px overflow-hidden rounded-lg border border-border bg-border">
    {
      stats.map((stat) => (
        <div class="flex flex-col gap-1 bg-card p-5">
          <span class="text-2xl font-semibold tracking-tight">{stat.value}</span>
          <span class="text-xs leading-snug text-muted-foreground sm:text-sm">
            {stat.label}
          </span>
        </div>
      ))
    }
  </section>

  <!-- Contact -->
  <section class="mt-14 rounded-lg border border-border bg-card p-6 sm:p-8">
    <h2 class="text-balance font-serif text-2xl italic text-foreground">
      Let&apos;s build something together.
    </h2>
    <p class="mt-2 max-w-md text-sm leading-relaxed text-muted-foreground">
      I&apos;m open to freelance work and full-time opportunities. The fastest
      way to reach me is by email.
    </p>
    <a
      href={`mailto:${site.email}`}
      class="mt-5 inline-flex h-10 items-center justify-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
    >
      {site.email}
      <ArrowUpRight class="size-4" />
    </a>
  </section>
</BaseLayout>
